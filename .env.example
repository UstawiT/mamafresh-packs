# ============================================================
# MamaFresh Packs - Environment Variables
# Copy to .env.local for local development.
# Add the same variables in Vercel > Project > Settings > Environment Variables.
# ============================================================

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp order number - international format, no plus sign.
# UPDATE THIS to your real business number.
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000

# Public site URL (used for SEO / Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# Google Apps Script Web App URL (server-side only - never exposed to the browser)
GOOGLE_SHEETS_WEBHOOK_URL=
